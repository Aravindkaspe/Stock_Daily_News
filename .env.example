# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# Gemini AI Studio API key — https://aistudio.google.com → Get API Key
GEMINI_API_KEY=AIza...

# Resend API key — https://resend.com → API Keys
RESEND_API_KEY=re_...

# Sender address — must be a verified domain in Resend.
# For testing you can use Resend's sandbox: onboarding@resend.dev
EMAIL_FROM=Stock Digest <digest@yourdomain.com>

# Your email — where the digest gets delivered
EMAIL_TO=you@example.com

# Optional: override the Gemini model. Defaults to gemini-2.0-flash.
# Set to gemini-2.0-flash or gemini-1.5-pro for higher quality.
# GEMINI_MODEL=gemini-2.0-flash